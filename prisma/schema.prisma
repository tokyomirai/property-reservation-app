generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  RECEIVED
  PENDING
  CONFIRMED
  CANCELLED
}

model Property {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  address     String?
  description String?
  images      String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  reservations Reservation[]
}

model Reservation {
  id           Int               @id @default(autoincrement())
  property      Property          @relation(fields: [propertyId], references: [id])
  propertyId    Int
  agencyName   String?
  contactName  String?
  phone        String?
  email        String
  desiredDate  DateTime?
  desiredTime  String?
  notes        String?
  status       ReservationStatus @default(RECEIVED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sentReplyAt  DateTime?
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
