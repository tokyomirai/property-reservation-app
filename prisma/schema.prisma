generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Property {
  id            String        @id @default(cuid())
  name          String
  address       String        @default("")
  salesStatus   String        @default("販売中")
  viewingStatus String        @default("内見可能")
  isPublished   Boolean       @default(true)
  hasKeyBox     String        @default("")
  keyBoxNumber  String        @default("")
  unlockCode    String        @default("")
  setupLocation String        @default("")
  hasSlippers   String        @default("")
  hasSignboard  String        @default("")
  notes         String        @default("")
  internalMemo  String        @default("")
  lastUpdatedBy String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reservations  Reservation[]
}

model Reservation {
  id            String   @id @default(cuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  propertyName  String
  companyName   String
  agentName     String
  phone         String
  email         String
  preferredDate String
  preferredTime String
  notes         String   @default("")
  status        String   @default("未承認")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

